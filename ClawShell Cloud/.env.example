# ClawShell Cloud 环境变量配置
# 复制此文件为 .env 并填入实际值

# ── JWT 认证 ──────────────────────────────────────────────
# JWT 密钥（建议 32+ 字符随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-me

# 用户标识
USER_ID=yangyang

# ── 阿里云 OSS（Obsidian Vault 云端存储）────────────────
# Bucket 名称（需先在 OSS 控制台创建）
OSS_BUCKET=clawshell-vault

# OSS Endpoint（区域地址，如 https://oss-cn-hangzhou.aliyuncs.com）
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# RAM 用户 AccessKey（建议使用子账号，权限仅限该 Bucket）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# Vault 前缀（Bucket 内的路径前缀，尾部斜杠可省略）
OSS_VAULT_PREFIX=vault/

# ── 可选配置 ─────────────────────────────────────────────
# 自定义域名（留空则使用 IP）
# DOMAIN=api.yourdomain.com
